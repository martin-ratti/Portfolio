---
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";
import ChatWidget from "../components/ChatWidget.astro";

interface Props {
	title: string;
	description?: string;
}

import { getLangFromUrl, useTranslations } from "../i18n/utils";
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const {
	title,
	description = t('seo.description'),
} = Astro.props;

const siteUrl = "https://martinratti.com.ar";
// Lógica para rutas alternativas: limpia /en del inicio para obtener la ruta base
const cleanPath = Astro.url.pathname.replace(/^\/en(\/|$)/, "$1") || "/";
const alternates = {
    es: new URL(cleanPath, siteUrl).href,
    en: new URL("/en" + (cleanPath.startsWith("/") ? cleanPath : "/" + cleanPath), siteUrl).href,
};
---

<!doctype html>
<html lang={lang} class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap"
			rel="stylesheet"
		/>
		<meta property="og:type" content="website" />
		<meta property="og:url" content={Astro.url} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content="/og-image.jpg" />

		<!-- SEO Expansion 1: Bidirectional Semantic Connection (hreflang) -->
		<link rel="canonical" href={lang === 'es' ? alternates.es : alternates.en} />
		<link rel="alternate" hreflang="es" href={alternates.es} />
		<link rel="alternate" hreflang="en" href={alternates.en} />
		<link rel="alternate" hreflang="x-default" href={alternates.en} />

		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:url" content={Astro.url} />
		<meta property="twitter:title" content={title} />
		<meta property="twitter:description" content={description} />
		<meta property="twitter:image" content="/og-image.jpg" />
		<ClientRouter />
		<script is:inline type="application/ld+json">
			{
			  "@context": "https://schema.org",
			  "@type": "Person",
			  "name": "Martín Ratti",
			  "url": "https://martinratti.com.ar",
			  "jobTitle": "Full Stack Developer",
			  "sameAs": [
				"https://github.com/martin-ratti",
				"https://www.linkedin.com/in/martin-ratti-dev/"
			  ],
			  "description": "Desarrollador Full Stack especializado en React, Node.js y Astro."
			}
		</script>
		<title>{title}</title>
	</head>
	<body
		class="bg-slate-50 text-slate-900 dark:bg-slate-950 dark:text-white selection:bg-fuchsia-500/30 relative"
	>
		<a href="#main-content" class="skip-link">{t('nav.skip')}</a>
		<div
			class="fixed inset-0 -z-10 h-full w-full bg-slate-50 dark:bg-slate-950"
		>
			<div
				class="absolute top-0 z-[-2] h-screen w-screen bg-[radial-gradient(ellipse_80%_80%_at_50%_-20%,rgba(120,119,198,0.15),rgba(255,255,255,0))] dark:bg-[radial-gradient(ellipse_80%_80%_at_50%_-20%,rgba(120,119,198,0.3),rgba(255,255,255,0))]"
			>
			</div>
			<div
				class="absolute bottom-0 left-0 right-0 top-0 bg-[linear-gradient(to_right,#80808012_1px,transparent_1px),linear-gradient(to_bottom,#80808012_1px,transparent_1px)] dark:bg-[linear-gradient(to_right,#4f4f4f2e_1px,transparent_1px),linear-gradient(to_bottom,#4f4f4f2e_1px,transparent_1px)] bg-size-[14px_24px] mask-[radial-gradient(ellipse_60%_50%_at_50%_0%,#000_70%,transparent_100%)]"
			>
			</div>
		</div>

		<script is:inline>
			const getTheme = () => {
				if (
					typeof localStorage !== "undefined" &&
					localStorage.getItem("theme")
				) {
					return localStorage.getItem("theme");
				}
				if (window.matchMedia("(prefers-color-scheme: dark)").matches) {
					return "dark";
				}
				return "light";
			};
			const applyTheme = () => {
				const theme = getTheme();
				if (theme === "dark") {
					document.documentElement.classList.add("dark");
				} else {
					document.documentElement.classList.remove("dark");
				}
				window.localStorage.setItem("theme", theme);
			};
			applyTheme();
			document.addEventListener("astro:after-swap", applyTheme);
		</script>

		<slot />

		<script>
			const initSpotlight = () => {
				const cards = document.querySelectorAll(".glass-card");
				if (cards.length === 0) return;

				// UI/UX Expansion 5: Optimización Pasiva con IntersectionObserver
				const visibleCards = new Set();
				
				const observer = new IntersectionObserver((entries) => {
					entries.forEach(entry => {
						if (entry.isIntersecting) {
							visibleCards.add(entry.target);
						} else {
							visibleCards.delete(entry.target);
						}
					});
				}, { threshold: 0.1 });

				cards.forEach(card => observer.observe(card));

				document.addEventListener(
					"mousemove",
					(e) => {
						if (visibleCards.size === 0) return;
						
						window.requestAnimationFrame(() => {
							visibleCards.forEach((card: any) => {
								const rect = card.getBoundingClientRect();
								const x = e.clientX - rect.left;
								const y = e.clientY - rect.top;
								card.style.setProperty("--mouse-x", `${x}px`);
								card.style.setProperty("--mouse-y", `${y}px`);
							});
						});
					},
					{ passive: true },
				);
			};

			const initThemeTransitions = () => {
				// UI/UX Expansion 4: Transición sin destellos
				setTimeout(() => {
					document.body.classList.add('theme-transitions-ready');
				}, 100);
			};

			initSpotlight();
			initThemeTransitions();
			document.addEventListener("astro:after-swap", () => {
				initSpotlight();
				initThemeTransitions();
			});
		</script>
		<ChatWidget />
	</body>
</html>
