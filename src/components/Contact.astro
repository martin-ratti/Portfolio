---
import { getLangFromUrl, useTranslations } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section id="contacto" class="py-20 px-4">
    <div
        class="glass-card max-w-5xl mx-auto rounded-3xl p-8 md:p-12 relative overflow-hidden animate-fade-in-up"
    >
        <div
            class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[300px] h-[300px] bg-violet-600/20 rounded-full blur-[80px] -z-10"
        >
        </div>

        <div
            class="grid grid-cols-1 md:grid-cols-2 gap-12 items-start text-left"
        >
            <!-- Columna Izquierda: Redes e Info -->
            <div class="flex flex-col h-full">
                <h2
                    class="text-4xl md:text-5xl font-bold mb-6 text-slate-900 dark:text-white"
                >
                    {t("contact.title")}
                </h2>

                <p
                    class="text-lg text-slate-600 dark:text-slate-300 mb-10 leading-relaxed max-w-md"
                >
                    {t("contact.desc")}
                </p>

                <div
                    class="flex flex-col gap-4 items-center md:items-start max-w-xs mx-auto md:mx-0"
                >
                    <a
                        href="https://mail.google.com/mail/?view=cm&fs=1&to=martinratti10@gmail.com"
                        target="_blank"
                        class="inline-flex items-center justify-center gap-3 px-8 py-3 glass-card border border-slate-200 dark:border-slate-700 font-medium rounded-2xl hover:bg-slate-100/50 dark:hover:bg-slate-800 transition text-slate-700 dark:text-slate-300 hover:text-red-500 dark:hover:text-red-400 w-full text-base group"
                    >
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            width="20"
                            height="20"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            class="group-hover:scale-110 transition-transform"
                            ><rect width="20" height="16" x="2" y="4" rx="2"
                            ></rect><path
                                d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"
                            ></path></svg
                        >
                        Email
                    </a>
                    <a
                        href="https://www.linkedin.com/in/martin-ratti-dev/"
                        target="_blank"
                        class="inline-flex items-center justify-center gap-3 px-8 py-3 glass-card border border-slate-200 dark:border-slate-700 font-medium rounded-2xl hover:bg-slate-100/50 dark:hover:bg-slate-800 transition text-slate-700 dark:text-slate-300 hover:text-[#0A66C2] dark:hover:text-[#0A66C2] w-full text-base group"
                    >
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            width="20"
                            height="20"
                            viewBox="0 0 24 24"
                            fill="currentColor"
                            class="group-hover:scale-110 transition-transform"
                        >
                            <path
                                d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
                            ></path>
                        </svg>
                        LinkedIn
                    </a>
                    <a
                        href="https://github.com/martin-ratti"
                        target="_blank"
                        class="inline-flex items-center justify-center gap-3 px-8 py-3 glass-card border border-slate-200 dark:border-slate-700 font-medium rounded-2xl hover:bg-slate-100/50 dark:hover:bg-slate-800 transition text-slate-700 dark:text-slate-300 hover:text-fuchsia-600 dark:hover:text-fuchsia-400 w-full text-base group"
                    >
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            width="20"
                            height="20"
                            viewBox="0 0 24 24"
                            fill="currentColor"
                            class="group-hover:scale-110 transition-transform"
                            ><path
                                d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"
                            ></path></svg
                        >
                        GitHub
                    </a>
                </div>
            </div>

            <!-- Columna Derecha: Formulario de Contacto -->
            <div class="w-full">
                <form
                    id="contact-form"
                    method="POST"
                    class="flex flex-col gap-4 bg-slate-50/50 dark:bg-slate-800/50 p-6 md:p-8 rounded-2xl border border-slate-200 dark:border-slate-700"
                >
                    <input
                        type="hidden"
                        name="access_key"
                        value="e3ffd7ce-28bb-40ba-a80d-dddc59051a14"
                    />
                    <!-- Componentes de Seguridad Web3Forms -->
                    <input
                        type="checkbox"
                        name="botcheck"
                        class="hidden"
                        style="display: none;"
                    />

                    <div class="flex flex-col gap-1.5">
                        <label
                            for="name"
                            class="text-sm font-medium text-slate-700 dark:text-slate-300 inline-block text-left"
                            >{t("contact.form.name")}</label
                        >
                        <input
                            type="text"
                            id="name"
                            name="name"
                            required
                            class="w-full bg-white dark:bg-slate-900 border border-slate-300 dark:border-slate-600 rounded-lg px-4 py-2 text-slate-900 dark:text-white focus:outline-none focus:border-violet-500 focus:ring-1 focus:ring-violet-500 transition-colors"
                        />
                    </div>

                    <div class="flex flex-col gap-1.5">
                        <label
                            for="email"
                            class="text-sm font-medium text-slate-700 dark:text-slate-300 inline-block text-left"
                            >{t("contact.form.email")}</label
                        >
                        <input
                            type="email"
                            id="email"
                            name="email"
                            required
                            class="w-full bg-white dark:bg-slate-900 border border-slate-300 dark:border-slate-600 rounded-lg px-4 py-2 text-slate-900 dark:text-white focus:outline-none focus:border-violet-500 focus:ring-1 focus:ring-violet-500 transition-colors"
                        />
                    </div>

                    <div class="flex flex-col gap-1.5">
                        <label
                            for="message"
                            class="text-sm font-medium text-slate-700 dark:text-slate-300 inline-block text-left"
                            >{t("contact.form.message")}</label
                        >
                        <textarea
                            id="message"
                            name="message"
                            rows="4"
                            required
                            class="w-full bg-white dark:bg-slate-900 border border-slate-300 dark:border-slate-600 rounded-lg px-4 py-2 text-slate-900 dark:text-white focus:outline-none focus:border-violet-500 focus:ring-1 focus:ring-violet-500 transition-colors resize-y"
                        ></textarea>
                    </div>

                    <button
                        type="submit"
                        class="mt-2 w-full bg-violet-600 hover:bg-violet-700 text-white font-medium py-3 px-4 rounded-lg transition-colors flex items-center justify-center gap-2 group"
                    >
                        <span id="submit-text">{t("contact.form.send")}</span>
                        <svg
                            class="w-4 h-4 group-hover:translate-x-1 transition-transform"
                            xmlns="http://www.w3.org/2000/svg"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                        >
                            <line x1="22" y1="2" x2="11" y2="13"></line>
                            <polygon points="22 2 15 22 11 13 2 9 22 2"
                            ></polygon>
                        </svg>
                    </button>

                    <div id="form-result" class="hidden animate-fade-in">
                        <div
                            class="flex items-center gap-3 p-4 rounded-xl border backdrop-blur-sm transition-all shadow-lg shadow-violet-500/5"
                        >
                            <div
                                id="result-icon"
                                class="flex-shrink-0 w-8 h-8 rounded-full flex items-center justify-center text-lg"
                            >
                            </div>
                            <p id="result-message" class="text-sm font-medium">
                            </p>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</section>

<script>
    function initContactForm() {
        const form = document.getElementById("contact-form") as HTMLFormElement;
        const result = document.getElementById("form-result");
        const submitBtn = form?.querySelector(
            'button[type="submit"]',
        ) as HTMLButtonElement;
        const submitText = document.getElementById("submit-text");

        if (!form || !result || !submitBtn || !submitText) return;

        const originalText = submitText.innerText;

        form.addEventListener("submit", function (e) {
            e.preventDefault();

            const emailValue = (
                form.querySelector('input[type="email"]') as HTMLInputElement
            ).value;
            if (!emailValue) return;

            // UI Feedback: Sending
            submitBtn.disabled = true;
            submitBtn.classList.add("opacity-70", "cursor-not-allowed");
            submitText.innerText = "...";
            result.classList.add("hidden");

            const formData = new FormData(form);
            const object = Object.fromEntries(formData);
            const json = JSON.stringify(object);

            fetch("https://api.web3forms.com/submit", {
                method: "POST",
                headers: {
                    "Content-Type": "application/json",
                    Accept: "application/json",
                },
                body: json,
            })
                .then(async (response) => {
                    const jsonResponse = await response.json();

                    submitBtn.disabled = false;
                    submitBtn.classList.remove(
                        "opacity-70",
                        "cursor-not-allowed",
                    );
                    submitText.innerText = originalText;

                    result.classList.remove("hidden");
                    const resultMessage =
                        document.getElementById("result-message");
                    const resultIcon = document.getElementById("result-icon");
                    const resultContainer = result.querySelector("div");

                    if (!resultMessage || !resultIcon || !resultContainer)
                        return;

                    if (response.status == 200) {
                        resultContainer.className =
                            "flex items-center gap-3 p-4 rounded-xl border backdrop-blur-sm transition-all shadow-lg shadow-green-500/10 bg-green-500/10 border-green-500/20 text-green-600 dark:text-green-400";
                        resultIcon.className =
                            "flex-shrink-0 w-8 h-8 rounded-full flex items-center justify-center text-lg bg-green-500/20";
                        resultIcon.innerText = "✅";
                        resultMessage.innerText =
                            jsonResponse.message ||
                            "Message sent successfully!";
                        form.reset();
                    } else {
                        resultContainer.className =
                            "flex items-center gap-3 p-4 rounded-xl border backdrop-blur-sm transition-all shadow-lg shadow-red-500/10 bg-red-500/10 border-red-500/20 text-red-500 dark:text-red-400";
                        resultIcon.className =
                            "flex-shrink-0 w-8 h-8 rounded-full flex items-center justify-center text-lg bg-red-500/20";
                        resultIcon.innerText = "⚠️";
                        resultMessage.innerText =
                            jsonResponse.message || "Error submitting form.";
                    }
                })
                .catch((error) => {
                    console.error(error);
                    result.classList.remove("hidden");
                    const resultMessage =
                        document.getElementById("result-message");
                    const resultIcon = document.getElementById("result-icon");
                    const resultContainer = result.querySelector("div");

                    if (resultMessage && resultIcon && resultContainer) {
                        resultContainer.className =
                            "flex items-center gap-3 p-4 rounded-xl border backdrop-blur-sm transition-all shadow-lg shadow-red-500/10 bg-red-500/10 border-red-500/20 text-red-500 dark:text-red-400";
                        resultIcon.className =
                            "flex-shrink-0 w-8 h-8 rounded-full flex items-center justify-center text-lg bg-red-500/20";
                        resultIcon.innerText = "⚠️";
                        resultMessage.innerText =
                            "Error alert: Something went wrong.";
                    }

                    submitBtn.disabled = false;
                    submitBtn.classList.remove(
                        "opacity-70",
                        "cursor-not-allowed",
                    );
                    submitText.innerText = originalText;
                })
                .finally(() => {
                    setTimeout(() => {
                        result.classList.add("hidden");
                    }, 5000);
                });
        });
    }

    document.addEventListener("astro:page-load", initContactForm);
</script>
