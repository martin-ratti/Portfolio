---
import { getLangFromUrl, useTranslations } from "../i18n/utils";
import { Icon } from "astro-icon/components";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<div
    id="chat-widget"
    class="fixed bottom-4 right-4 z-50 flex flex-col items-end pointer-events-none"
    data-lang={lang}
    data-error-server={t("chat.error.server")}
    data-error-connection={t("chat.error.connection")}
    data-error-prefix={t("chat.error.prefix")}
>
    <div
        id="chat-widget"
        class="fixed bottom-4 right-4 z-50 flex flex-col items-end pointer-events-none"
    >
        <div
            id="chat-window"
            class="pointer-events-auto transition-all duration-300 transform origin-bottom-right scale-0 opacity-0 mb-4 w-[350px] max-w-[calc(100vw-2rem)] h-[600px] max-h-[80vh] flex flex-col bg-white/80 dark:bg-slate-900/80 backdrop-blur-xl border border-white/20 dark:border-white/10 rounded-2xl shadow-2xl overflow-hidden"
        >
            <div
                class="p-4 border-b border-black/5 dark:border-white/10 bg-white/50 dark:bg-black/20 flex justify-between items-center"
            >
                <div class="flex items-center gap-3">
                    <div class="relative">
                        <div
                            class="w-2 h-2 absolute bottom-0 right-0 bg-green-500 rounded-full ring-2 ring-white dark:ring-slate-800"
                        >
                        </div>
                        <div
                            class="w-8 h-8 rounded-full bg-linear-to-tr from-violet-500 to-fuchsia-500 flex items-center justify-center text-white text-xs font-bold"
                        >
                            AI
                        </div>
                    </div>
                    <div>
                        <h3
                            class="font-bold text-sm text-slate-900 dark:text-white"
                        >
                            {t("chat.name")}
                        </h3>
                        <p
                            class="text-[10px] text-slate-500 dark:text-slate-400"
                        >
                            {t("chat.powered")}
                        </p>
                    </div>
                </div>
                <button
                    id="close-chat"
                    class="text-slate-500 hover:text-slate-700 dark:text-slate-400 dark:hover:text-white transition-colors"
                >
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="20"
                        height="20"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        ><line x1="18" y1="6" x2="6" y2="18"></line><line
                            x1="6"
                            y1="6"
                            x2="18"
                            y2="18"></line></svg
                    >
                </button>
            </div>

            <div
                id="messages-container"
                class="flex-1 overflow-y-auto p-4 space-y-4 scroll-smooth"
            >
                <div class="flex gap-3">
                    <div
                        class="w-8 h-8 rounded-full bg-linear-to-tr from-violet-500 to-fuchsia-500 shrink-0 flex items-center justify-center text-white text-xs font-bold"
                    >
                        AI
                    </div>
                    <div
                        class="bg-white dark:bg-slate-800 p-3 rounded-2xl rounded-tl-none border border-black/5 dark:border-white/10 shadow-sm max-w-[85%]"
                    >
                        <p class="text-sm text-slate-600 dark:text-slate-300">
                            {t("chat.greeting")}
                            <Icon name="mdi:hand-wave" class="w-4 h-4 text-amber-500 inline-block align-text-bottom ml-1" />
                        </p>
                    </div>
                </div>
            </div>

            <div
                class="p-4 border-t border-black/5 dark:border-white/10 bg-white/50 dark:bg-black/20"
            >
                <!-- Prompt Chips Container -->
                <div 
                    id="chips-container" 
                    class="flex flex-nowrap gap-2 overflow-x-auto pb-2 mb-1 transition-opacity duration-300 items-center snap-x snap-mandatory custom-scrollbar"
                >
                    <button class="chat-chip group flex items-center gap-2 whitespace-nowrap px-4 py-2 rounded-full text-xs font-medium bg-white/80 dark:bg-slate-800/80 border border-slate-200 dark:border-white/10 hover:border-violet-500 dark:hover:border-violet-400 hover:bg-violet-50 dark:hover:bg-violet-500/10 hover:shadow-md transition-all cursor-pointer text-slate-700 dark:text-slate-200 shadow-sm" data-message={t("chat.suggestion1")}>
                        <Icon name="simple-icons:astro" class="w-3.5 h-3.5 text-violet-500" />
                        <span>{t("chat.suggestion1")}</span>
                    </button>
                    <button class="chat-chip group flex items-center gap-2 whitespace-nowrap px-4 py-2 rounded-full text-xs font-medium bg-white/80 dark:bg-slate-800/80 border border-slate-200 dark:border-white/10 hover:border-violet-500 dark:hover:border-violet-400 hover:bg-violet-50 dark:hover:bg-violet-500/10 hover:shadow-md transition-all cursor-pointer text-slate-700 dark:text-slate-200 shadow-sm" data-message={t("chat.suggestion2")}>
                        <Icon name="mdi:layers-outline" class="w-3.5 h-3.5 text-fuchsia-500" />
                        <span>{t("chat.suggestion2")}</span>
                    </button>
                    <button class="chat-chip group flex items-center gap-2 whitespace-nowrap px-4 py-2 rounded-full text-xs font-medium bg-white/80 dark:bg-slate-800/80 border border-slate-200 dark:border-white/10 hover:border-violet-500 dark:hover:border-violet-400 hover:bg-violet-50 dark:hover:bg-violet-500/10 hover:shadow-md transition-all cursor-pointer text-slate-700 dark:text-slate-200 shadow-sm" data-message={t("chat.suggestion3")}>
                        <Icon name="mdi:code-tags" class="w-3.5 h-3.5 text-blue-500" />
                        <span>{t("chat.suggestion3")}</span>
                    </button>
                    <!-- Espaciador final para el scroll -->
                    <div class="w-4 shrink-0"></div>
                </div>

                <form id="chat-form" class="relative">
                    <input
                        type="text"
                        id="chat-input"
                        placeholder={t("chat.placeholder")}
                        class="w-full bg-white dark:bg-slate-800 border border-black/10 dark:border-white/10 rounded-xl pl-4 pr-12 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-violet-500 dark:text-white placeholder-slate-400"
                    />
                    <button
                        type="submit"
                        class="absolute right-2 top-1/2 -translate-y-1/2 p-1.5 bg-violet-500 hover:bg-violet-600 text-white rounded-lg transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
                    >
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            width="16"
                            height="16"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            ><line x1="22" y1="2" x2="11" y2="13"
                            ></line><polygon points="22 2 15 22 11 13 2 9 22 2"
                            ></polygon></svg
                        >
                    </button>
                </form>
            </div>
        </div>

        <button
            id="chat-toggle"
            class="pointer-events-auto group relative flex items-center justify-center w-16 h-16 bg-linear-to-tr from-violet-600 to-fuchsia-600 text-white rounded-full shadow-2xl hover:scale-110 transition-all duration-300 z-50 ring-4 ring-white/20 dark:ring-black/20"
            aria-label="Abrir chat con Martín AI"
        >
            <span
                class="absolute inline-flex h-full w-full rounded-full bg-fuchsia-500 opacity-20 animate-ping duration-2000 -z-10"
            ></span>

            <span class="absolute top-1 right-1 flex h-4 w-4">
                <span
                    class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"
                ></span>
                <span
                    class="relative inline-flex rounded-full h-4 w-4 bg-green-500 border-2 border-white dark:border-slate-900"
                ></span>
            </span>

            <svg
                id="icon-message"
                class="absolute transition-all duration-300 transform group-hover:scale-0 w-8 h-8"
                xmlns="http://www.w3.org/2000/svg"
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><path
                    d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"
                ></path></svg
            >
            <svg
                id="icon-close"
                class="absolute transition-all duration-300 transform scale-0 group-hover:scale-100 w-8 h-8"
                xmlns="http://www.w3.org/2000/svg"
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><line x1="18" y1="6" x2="6" y2="18"></line><line
                    x1="6"
                    y1="6"
                    x2="18"
                    y2="18"></line></svg
            >

            <span
                id="chat-tooltip"
                class="absolute right-full mr-4 top-1/2 -translate-y-1/2 bg-white dark:bg-slate-800 text-slate-800 dark:text-white text-xs font-bold px-3 py-1.5 rounded-lg opacity-0 -translate-x-2 transition-all duration-300 shadow-lg whitespace-nowrap pointer-events-none border border-black/5 dark:border-white/10"
            >
                {t("chat.tooltip")}
            </span>
        </button>
    </div>

    <script>
        import { sendChatMessage } from "../utils/chat/chatApi";
        import {
            addMessageToDOM,
            showTypingIndicator,
            hideTypingIndicator,
            setupFocusTrap,
            releaseFocusTrap,
        } from "../utils/chat/chatUi";
        import type { ChatMessage } from "../utils/chat/chatApi";

        let isOpen = false;
        let messages: ChatMessage[] = [];

        let widget: HTMLElement | null = null;
        let toggleBtn: HTMLElement | null = null;
        let windowEl: HTMLElement | null = null;
        let closeBtn: HTMLElement | null = null;
        let form: HTMLFormElement | null = null;
        let input: HTMLInputElement | null = null;
        let messagesContainer: HTMLElement | null = null;
        let messageIcon: HTMLElement | null = null;
        let closeIcon: HTMLElement | null = null;
        let tooltip: HTMLElement | null = null;
        let chipsContainer: HTMLElement | null = null;

        let tooltipTimer: ReturnType<typeof setTimeout> | null = null;
        let hideTooltipTimer: ReturnType<typeof setTimeout> | null = null;

        let currentLang = "es";
        let errServer = "Lo siento, no pude conectar con el servidor.";
        let errConnection = "Lo siento, hubo un error de conexión.";
        let errPrefix = 'Error:';
        const errorIcon = '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="inline-block mr-1 text-red-500"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/><path d="M12 9v4"/><path d="M12 17h.01"/></svg>';

        function showTooltip() {
            if (!tooltip || isOpen) return;
            tooltip.classList.remove("opacity-0", "-translate-x-2");
            tooltip.classList.add("opacity-100", "translate-x-0", "animate-bounce-subtle");
        }

        function hideTooltip() {
            if (!tooltip) return;
            tooltip.classList.add("opacity-0", "-translate-x-2");
            tooltip.classList.remove("opacity-100", "translate-x-0", "animate-bounce-subtle");
        }

        function toggleChat() {
            isOpen = !isOpen;
            if (isOpen) {
                hideTooltip();
                if (tooltipTimer) clearTimeout(tooltipTimer);
                if (hideTooltipTimer) clearTimeout(hideTooltipTimer);

                windowEl?.classList.remove("scale-0", "opacity-0");
                messageIcon?.classList.add("scale-0");
                closeIcon?.classList.remove("scale-0");

                if (windowEl && toggleBtn) {
                    setupFocusTrap(windowEl, toggleBtn);
                }

                setTimeout(() => input?.focus(), 300);
            } else {
                windowEl?.classList.add("scale-0", "opacity-0");
                messageIcon?.classList.remove("scale-0");
                closeIcon?.classList.add("scale-0");

                releaseFocusTrap();
            }
        }

        async function sendMessage(text: string) {
            if (!messagesContainer) return;

            addMessageToDOM(messagesContainer, "user", text);
            if (input) input.value = "";
            messages.push({ role: "user", content: text });

            showTypingIndicator(messagesContainer);

            const response = await sendChatMessage(messages, currentLang);
            hideTypingIndicator();

            if (response.error) {
                if (response.error === "Network error") {
                    addMessageToDOM(messagesContainer, "assistant", errServer);
                } else {
                    addMessageToDOM(
                        messagesContainer,
                        "assistant",
                        `${errorIcon} **${errPrefix}** ${response.error}`,
                    );
                }
            } else if (response.reply) {
                addMessageToDOM(messagesContainer, "assistant", response.reply);
                messages.push({ role: "assistant", content: response.reply });
            } else {
                addMessageToDOM(messagesContainer, "assistant", errConnection);
            }
        }

        async function handleChatSubmit(e: SubmitEvent) {
            e.preventDefault();
            if (!input) return;

            const text = input.value.trim();
            if (!text) return;

            sendMessage(text);
        }

        function handleChipClick(e: Event) {
            const btn = (e.currentTarget as HTMLElement).closest('.chat-chip') as HTMLButtonElement;
            const message = btn.dataset.message;
            if (message) {
                sendMessage(message);
                
                // Animación de salida para los chips
                if (chipsContainer) {
                    chipsContainer.classList.add('opacity-0', 'pointer-events-none');
                    setTimeout(() => {
                        chipsContainer?.classList.add('hidden');
                    }, 300);
                }
            }
        }

        function initChatWidget() {
            widget = document.getElementById("chat-widget");
            toggleBtn = document.getElementById("chat-toggle");
            windowEl = document.getElementById("chat-window");
            closeBtn = document.getElementById("close-chat");
            form = document.getElementById("chat-form") as HTMLFormElement;
            input = document.getElementById("chat-input") as HTMLInputElement;
            messagesContainer = document.getElementById("messages-container");
            messageIcon = document.getElementById("icon-message");
            closeIcon = document.getElementById("icon-close");
            tooltip = document.getElementById("chat-tooltip");
            chipsContainer = document.getElementById("chips-container");

            if (widget) {
                currentLang = widget.dataset.lang || "es";
                errServer =
                    widget.dataset.errorServer ||
                    "Lo siento, no pude conectar con el servidor.";
                errConnection =
                    widget.dataset.errorConnection ||
                    "Lo siento, hubo un error de conexión.";
                errPrefix = widget.dataset.errorPrefix || "⚠️ Error:";
            }

            toggleBtn?.removeEventListener("click", toggleChat);
            closeBtn?.removeEventListener("click", toggleChat);
            form?.removeEventListener("submit", handleChatSubmit);

            toggleBtn?.addEventListener("click", toggleChat);
            closeBtn?.addEventListener("click", toggleChat);
            form?.addEventListener("submit", handleChatSubmit);

            // Chips click events
            document.querySelectorAll(".chat-chip").forEach(chip => {
                chip.addEventListener("click", handleChipClick);
            });

            // Hover effects for manual visibility
            toggleBtn?.addEventListener("mouseenter", showTooltip);
            toggleBtn?.addEventListener("mouseleave", hideTooltip);

            // Proactive Tooltip Timer
            tooltipTimer = setTimeout(() => {
                showTooltip();
                
                // Auto hide after 5 seconds
                hideTooltipTimer = setTimeout(hideTooltip, 5000);
            }, 6000); // 6 seconds after load
        }

        document.addEventListener("astro:page-load", initChatWidget);
    </script>

    <style is:global>
        /* Estilos para el contenido Markdown del chat */
        .prose p {
            margin-bottom: 0.75em;
            line-height: 1.6;
        }
        .prose p:last-child {
            margin-bottom: 0;
        }
        .prose strong {
            font-weight: 700;
            color: inherit;
        }
        .prose a {
            color: #d946ef; /* fuchsia-500 */
            font-weight: 600;
            text-decoration: none;
            transition: all 0.2s;
            border-bottom: 1px solid transparent;
        }
        .prose a:hover {
            color: #8b5cf6; /* violet-500 */
            text-decoration: underline;
        }
        .dark .prose a {
            color: #d946ef;
        }
        .prose ul,
        .prose ol {
            margin-left: 1.25em;
            margin-bottom: 0.75em;
            list-style-type: disc;
        }
        .prose li {
            margin-bottom: 0.35em;
        }
        .prose code {
            background-color: rgba(139, 92, 246, 0.1);
            color: #8b5cf6;
            padding: 0.2em 0.4em;
            border-radius: 0.375em;
            font-family: inherit;
            font-weight: 600;
            font-size: 0.9em;
        }
        .dark .prose code {
            background-color: rgba(217, 70, 239, 0.15);
            color: #f472b6;
        }
        .prose pre {
            background-color: #1e293b;
            color: #e2e8f0;
            padding: 0.75em;
            border-radius: 0.5em;
            overflow-x: auto;
            margin-bottom: 0.75em;
            font-size: 0.85em;
        }
        .prose pre code {
            background-color: transparent;
            padding: 0;
            color: inherit;
            font-weight: 400;
        }

        /* Chips Styles */
        /* Scrollbar styles moved to .custom-scrollbar */
        /* Custom Scrollbar for Chips */
        .custom-scrollbar::-webkit-scrollbar {
            height: 4px;
        }
        .custom-scrollbar::-webkit-scrollbar-track {
            background: rgba(0, 0, 0, 0.05);
            border-radius: 10px;
        }
        .dark .custom-scrollbar::-webkit-scrollbar-track {
            background: rgba(255, 255, 255, 0.05);
        }
        .custom-scrollbar::-webkit-scrollbar-thumb {
            background: rgba(139, 92, 246, 0.3);
            border-radius: 10px;
        }
        .custom-scrollbar::-webkit-scrollbar-thumb:hover {
            background: rgba(139, 92, 246, 0.5);
        }

        .chat-chip {
            snap-align: start;
        }
        .mask-fade-right {
            mask-image: linear-gradient(to right, black 90%, transparent 100%);
        }

        @keyframes bounce-subtle {
            0%, 100% { transform: translateY(-50%) translateX(0); }
            50% { transform: translateY(-50%) translateX(-5px); }
        }
        .animate-bounce-subtle {
            animation: bounce-subtle 2s infinite;
        }
    </style>
</div>
