---
import { projects } from "../data/projects";
import { getLangFromUrl, useTranslations } from "../i18n/utils";
import ProjectCard from "./ProjectCard.astro";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const featuredProjects = projects.filter((p) => p.featured);
const otherProjects = projects.filter((p) => !p.featured);
---

<section id="proyectos" class="py-20 px-4 max-w-7xl mx-auto">
    <h2 class="text-4xl md:text-5xl font-bold mb-16 text-center">
        <span class="text-gradient leading-relaxed py-2"
            >{t("projects.title")}</span
        >
    </h2>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-16">
        {
            featuredProjects.map((project, index) => (
                <ProjectCard
                    project={project}
                    index={index}
                    featured={true}
                    baseDelay={0}
                />
            ))
        }
    </div>

    <h3
        class="text-3xl font-bold mb-10 text-center text-slate-700 dark:text-slate-300"
    >
        {t("projects.other")}
    </h3>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {
            otherProjects.map((project, index) => (
                <ProjectCard
                    project={project}
                    index={index}
                    featured={false}
                    baseDelay={featuredProjects.length * 0.1}
                />
            ))
        }
    </div>
</section>

<style>
    @keyframes success-flash {
        0% {
            box-shadow: 0 0 0 0 rgba(139, 92, 246, 0);
            transform: scale(1.05);
        }
        30% {
            box-shadow: 0 0 25px 10px rgba(139, 92, 246, 0.6);
            transform: scale(1.08);
        }
        100% {
            box-shadow: 0 0 0 0 rgba(139, 92, 246, 0);
            transform: scale(1.05);
        }
    }

    .animate-success-flash {
        animation: success-flash 1.2s ease-out forwards;
    }
</style>

<script>
    let isListenerAdded = false;

    function initProjectsFilter() {
        if (isListenerAdded) return;

        window.addEventListener("filter-projects", (e: Event) => {
            const customEvent = e as CustomEvent;
            const selectedSkill = customEvent.detail?.skill;
            const cards = document.querySelectorAll(".project-card");

            if (!selectedSkill) {
                cards.forEach((card) => {
                    const el = card as HTMLElement;
                    el.style.opacity = "1";
                    el.style.filter = "grayscale(0)";
                    el.style.transform = "scale(1)";
                    el.style.borderColor = "transparent";
                    el.style.zIndex = "0";
                    el.style.boxShadow = "none";
                    el.classList.remove("animate-success-flash");
                });
                return;
            }

            let firstMatch: HTMLElement | null = null;

            cards.forEach((card) => {
                const el = card as HTMLElement;
                const techs = JSON.parse(
                    el.getAttribute("data-techs") || "[]",
                );

                el.classList.remove("animate-success-flash");

                if (techs.includes(selectedSkill)) {
                    el.style.opacity = "1";
                    el.style.filter =
                        "grayscale(0) drop-shadow(0 0 15px rgba(139, 92, 246, 0.4))";
                    el.style.transform = "scale(1.05)";
                    el.style.borderColor = "rgba(139, 92, 246, 0.8)";
                    el.style.zIndex = "10";
                    if (!firstMatch) firstMatch = el;
                } else {
                    el.style.opacity = "0.1";
                    el.style.filter = "grayscale(100%) blur(2px)";
                    el.style.transform = "scale(0.95)";
                    el.style.borderColor = "transparent";
                    el.style.zIndex = "0";
                    el.style.boxShadow = "none";
                }
            });

            if (firstMatch) {
                const matchEl = firstMatch as HTMLElement;
                // Pequeño delay para dejar que las transiciones de CSS comiencen
                setTimeout(() => {
                    matchEl.scrollIntoView({
                        behavior: "smooth",
                        block: "center",
                    });
                    
                    // Disparamos el flash después de que el scroll haya avanzado (aprox 600ms)
                    setTimeout(() => {
                        matchEl.classList.add("animate-success-flash");
                    }, 500);
                }, 100);
            }
        });

        isListenerAdded = true;
    }

    document.addEventListener("astro:page-load", initProjectsFilter);
</script>
