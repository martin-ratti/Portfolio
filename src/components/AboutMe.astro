---
import { getLangFromUrl, useTranslations } from "../i18n/utils";
import { Icon } from "astro-icon/components";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section id="sobre-mi" class="py-20 px-4 max-w-6xl mx-auto">
    <h2
        class="text-3xl font-bold mb-12 text-center flex items-center justify-center gap-3"
    >
        <svg
            xmlns="http://www.w3.org/2000/svg"
            width="32"
            height="32"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="text-violet-400"
            ><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle
                cx="12"
                cy="7"
                r="4"></circle></svg
        >
        {t("about.title")}
    </h2>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <article
            class="md:col-span-2 glass-card p-10 md:p-12 rounded-3xl flex flex-col justify-center relative overflow-hidden group shadow-xl shadow-slate-200/50 dark:shadow-none"
        >
            <div
                class="absolute inset-0 bg-linear-to-br from-violet-500/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"
            >
            </div>
            <p
                class="text-xl md:text-2xl font-medium text-slate-900 dark:text-white leading-relaxed relative z-10 mb-6"
            >
                {t("about.story")}
            </p>
            <p
                class="text-lg text-slate-500 dark:text-slate-400 leading-relaxed relative z-10"
            >
                {t("about.specialty")}
            </p>
        </article>

        <article
            class="glass-card rounded-3xl p-6 flex items-center justify-center bg-linear-to-br from-violet-500/5 to-fuchsia-500/5 shadow-xl shadow-slate-200/50 dark:shadow-none"
        >
            <div
                class="w-full h-full min-h-[300px] bg-white/50 dark:bg-slate-800/50 rounded-2xl flex items-center justify-center relative overflow-hidden group/photo border border-slate-200 dark:border-slate-700 shadow-inner"
            >
                <div
                    class="absolute inset-0 bg-linear-to-tr from-violet-500/10 to-transparent"
                >
                </div>
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="80"
                    height="80"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="text-slate-300 dark:text-slate-600 transition-transform duration-700 group-hover/photo:scale-110"
                >
                    <path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"></path>
                    <circle cx="12" cy="7" r="4"></circle>
                </svg>
                <div
                    class="absolute inset-x-0 bottom-0 p-4 bg-slate-900/80 backdrop-blur-md transform translate-y-full group-hover/photo:translate-y-0 transition-transform duration-500 flex items-center justify-center"
                >
                    <span
                        class="text-xs font-bold text-white uppercase tracking-[0.2em]"
                        >{t("about.photo")}</span
                    >
                </div>
            </div>
        </article>

        <article
            class="glass-card p-10 md:p-12 rounded-3xl md:col-span-1 flex flex-col justify-center hover:bg-white/80 dark:hover:bg-slate-800/60 transition-all duration-500 shadow-xl shadow-slate-200/50 dark:shadow-none border border-slate-200 dark:border-slate-700"
        >
            <h3
                class="text-2xl font-bold text-fuchsia-600 dark:text-fuchsia-300 mb-4"
            >
                {t("about.education.title")}
            </h3>
            <p class="text-lg text-slate-600 dark:text-slate-400 leading-relaxed">
                {t("about.education.desc")}
            </p>
        </article>

        <article
            class="glass-card p-10 md:p-12 rounded-3xl md:col-span-2 flex flex-col justify-center shadow-xl shadow-slate-200/50 dark:shadow-none border border-slate-200 dark:border-slate-700"
        >
            <h3
                class="text-2xl font-bold text-emerald-600 dark:text-emerald-300 mb-8"
            >
                {t("about.skills.title")}
            </h3>
            <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
                <div class="group/skill flex flex-col items-center justify-center p-6 rounded-2xl bg-white/40 dark:bg-slate-900/40 border border-slate-200 dark:border-slate-800 hover:border-violet-500/50 hover:bg-violet-500/5 transition-all duration-300 hover:-translate-y-1">
                    <Icon name="mdi:lightning-bolt" class="w-10 h-10 mb-3 text-amber-500 transform transition-transform duration-300 group-hover/skill:scale-125" />
                    <span class="text-sm font-bold text-slate-700 dark:text-slate-200 tracking-wide">{t("about.skills.proactive")}</span>
                </div>
                
                <div class="group/skill flex flex-col items-center justify-center p-6 rounded-2xl bg-white/40 dark:bg-slate-900/40 border border-slate-200 dark:border-slate-800 hover:border-sky-500/50 hover:bg-sky-500/5 transition-all duration-300 hover:-translate-y-1">
                    <Icon name="mdi:magnify" class="w-10 h-10 mb-3 text-sky-500 transform transition-transform duration-300 group-hover/skill:scale-125" />
                    <span class="text-sm font-bold text-slate-700 dark:text-slate-200 tracking-wide">{t("about.skills.curious")}</span>
                </div>

                <div class="group/skill flex flex-col items-center justify-center p-6 rounded-2xl bg-white/40 dark:bg-slate-900/40 border border-slate-200 dark:border-slate-800 hover:border-emerald-500/50 hover:bg-emerald-500/5 transition-all duration-300 hover:-translate-y-1">
                    <Icon name="mdi:lightbulb-on" class="w-10 h-10 mb-3 text-emerald-500 transform transition-transform duration-300 group-hover/skill:scale-125" />
                    <span class="text-sm font-bold text-slate-700 dark:text-slate-200 tracking-wide text-center">{t("about.skills.solution")}</span>
                </div>

                <div class="group/skill flex flex-col items-center justify-center p-6 rounded-2xl bg-white/40 dark:bg-slate-900/40 border border-slate-200 dark:border-slate-800 hover:border-fuchsia-500/50 hover:bg-fuchsia-500/5 transition-all duration-300 hover:-translate-y-1">
                    <Icon name="mdi:auto-fix" class="w-10 h-10 mb-3 text-fuchsia-500 transform transition-transform duration-300 group-hover/skill:scale-125" />
                    <span class="text-sm font-bold text-slate-700 dark:text-slate-200 tracking-wide">{t("about.skills.clean")}</span>
                </div>
            </div>
        </article>
    </div>
</section>
